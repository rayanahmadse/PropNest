@model PropNest.Models.Staff
@{
    ViewData["Title"] = "Staff Member Details";
}

<div class="page-header mt-4">
    <div>
        <h1>Staff Member Details</h1>
        <p>Operational profile, contact channel, and status for @Model.FullName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.StaffID" class="btn btn-apple">✏️ Edit Staff</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <!-- Profile specs Card (8 columns) -->
    <div class="col-12 col-md-8">
        <div class="apple-card p-4">
            <h5 class="fw-bold mb-4 pb-2 border-bottom">Member Profile</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Full Name</label>
                    <div class="fw-600">@Model.FullName</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Contact Number</label>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.ContactNumber))
                        {
                            <a href="tel:@Model.ContactNumber" class="text-decoration-none">@Model.ContactNumber</a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Specialty / Role</label>
                    <div><span class="badge bg-light text-dark border">@Model.Specialty</span></div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Staff ID Code</label>
                    <div><code>Staff-@Model.StaffID</code></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Sidebar (4 columns) -->
    <div class="col-12 col-md-4">
        <div class="apple-card p-4">
            <h5 class="fw-bold mb-4 pb-2 border-bottom">System Status</h5>
            <div class="mb-4">
                <label class="form-label text-muted small uppercase">Duty Status</label>
                <div>
                    @{
                        var sc = Model.Status == "Active" ? "status-active" : "status-inactive";
                    }
                    <span class="status-badge @sc">@Model.Status</span>
                </div>
            </div>
        </div>
    </div>
</div>
