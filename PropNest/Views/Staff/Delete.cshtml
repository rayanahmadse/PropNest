@model PropNest.Models.Staff

@{
    ViewData["Title"] = "Delete Staff";
}

<div class="page-header mt-4">
    <div>
        <h1>Delete Staff Profile</h1>
        <p>Confirm the removal of staff profile</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card max-width-600">
    <div class="alert alert-danger mb-4">
        <strong>⚠️ Warning:</strong> Are you sure you want to delete this staff profile? This action is permanent and cannot be undone.
    </div>

    <div class="apple-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Staff Information</h5>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Full Name</label>
            <div class="fw-600">@Model.FullName</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Specialty / Role</label>
            <div>@Model.Specialty</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Contact Number</label>
            <div>@Model.ContactNumber</div>
        </div>
        <div class="mb-0">
            <label class="form-label text-muted small uppercase">Duty Status</label>
            <div>@Model.Status</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="StaffID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-apple btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
