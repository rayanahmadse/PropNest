@model PropNest.Models.RentPayment

@{
    ViewData["Title"] = "Payment Details";
}

<h1>Payment Details</h1>
<hr />
<dl class="row">
    <dt class="col-sm-3">Lease ID</dt>
    <dd class="col-sm-9">@Model.LeaseID</dd>
    <dt class="col-sm-3">Due Date</dt>
    <dd class="col-sm-9">@Model.DueDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Payment Date</dt>
    <dd class="col-sm-9">@(Model.PaymentDate.HasValue ? Model.PaymentDate.Value.ToShortDateString() : "-")</dd>
    <dt class="col-sm-3">Amount Paid</dt>
    <dd class="col-sm-9">@Model.AmountPaid</dd>
    <dt class="col-sm-3">Method</dt>
    <dd class="col-sm-9">@(Model.PaymentMethod ?? "-")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.PaymentID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
