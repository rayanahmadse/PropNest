@model PropNest.Models.RentPayment
@{
    ViewData["Title"] = "Payment Details";
}

<div class="page-header mt-4">
    <div>
        <h1>Rent Payment Details</h1>
        <p>Operational receipt record for invoice payment #@Model.PaymentID</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.PaymentID" class="btn btn-apple">✏️ Edit Payment</a>
        <a asp-action="Delete" asp-route-id="@Model.PaymentID" class="btn btn-outline-danger">🗑 Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <!-- Payment details Card (8 columns) -->
    <div class="col-12 col-md-8">
        <div class="apple-card p-4">
            <h5 class="fw-bold mb-4 pb-2 border-bottom">Payment Audit</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Agreement Link</label>
                    <div>
                        @if (Model.RentalAgreement != null)
                        {
                            <a class="fw-600 text-decoration-none" asp-controller="RentalAgreements" asp-action="Details" asp-route-id="@Model.RentalAgreement.AgreementID">
                                📋 Agreement #@Model.RentalAgreement.AgreementID
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No agreement linked.</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Tenant Link</label>
                    <div>
                        @if (Model.RentalAgreement?.Tenant != null)
                        {
                            <a class="fw-600 text-decoration-none" asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.RentalAgreement.Tenant.TenantID">
                                👤 @Model.RentalAgreement.Tenant.FullName
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Payment Method</label>
                    <div>@(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "—" : Model.PaymentMethod)</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Due Date</label>
                    <div>@Model.DueDate.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Actual Payment Date</label>
                    <div>@(Model.PaymentDate.HasValue ? Model.PaymentDate.Value.ToString("MMMM dd, yyyy") : "Not paid yet")</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Amount Paid</label>
                    <div class="fw-600">Rs. @Model.AmountPaid.ToString("N0")</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Late Fee Applied</label>
                    <div>
                        Rs. @Model.LateFeeAmount.ToString("N0")
                        @if (Model.LateFeeApplied)
                        {
                            <span class="badge bg-danger ms-2">Applied</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Operational tools -->
            <h5 class="fw-bold mb-3 pb-2 border-bottom">Receipt & Reminder Controls</h5>
            <div class="d-flex gap-2 flex-wrap">
                <form asp-action="GenerateReceipt" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.PaymentID" />
                    <button type="submit" class="btn btn-outline-secondary">Generate Receipt</button>
                </form>
                
                @if (Model.ReceiptGenerated)
                {
                    <a href="https://localhost:7120/api/RentPayments/@Model.PaymentID/receipt" target="_blank" class="btn btn-apple">
                        Download PDF Receipt
                    </a>
                }
                else
                {
                    <a asp-action="DownloadReceipt" asp-route-id="@Model.PaymentID" class="btn btn-outline-secondary">Download PDF Receipt</a>
                }

                @if (!Model.ReminderSent)
                {
                    <a asp-action="MarkReminderSent" asp-route-id="@Model.PaymentID" class="btn btn-outline-secondary">✉️ Send Reminder Notice</a>
                }
                else
                {
                    <span class="btn btn-sm btn-light border text-muted disabled">✉️ Reminder Sent</span>
                }
            </div>
        </div>
    </div>

    <!-- Status Sidebar (4 columns) -->
    <div class="col-12 col-md-4">
        <div class="apple-card p-4">
            <h5 class="fw-bold mb-4 pb-2 border-bottom">Operational Status</h5>
            <div class="mb-4">
                <label class="form-label text-muted small uppercase">Payment Status</label>
                <div>
                    @{
                        var sc = Model.Status switch {
                            "Paid"    => "status-paid",
                            "Overdue" => "status-overdue",
                            _         => "status-pending"
                        };
                    }
                    <span class="status-badge @sc">@Model.Status</span>
                </div>
            </div>
            <div class="mb-0">
                <label class="form-label text-muted small uppercase">Reminder Logs</label>
                <div class="small text-muted">
                    @(Model.ReminderSent ? $"Last reminder dispatched on {Model.ReminderSentAt?.ToString("MMM dd, yyyy")}" : "No reminders dispatched yet.")
                </div>
            </div>
        </div>
    </div>
</div>
