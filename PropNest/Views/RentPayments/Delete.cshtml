@model PropNest.Models.RentPayment

@{
    ViewData["Title"] = "Delete Payment";
}

<div class="page-header mt-4">
    <div>
        <h1>Delete Rent Payment</h1>
        <p>Confirm the removal of rent payment ledger</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card max-width-600">
    <div class="alert alert-danger mb-4">
        <strong>⚠️ Warning:</strong> Are you sure you want to delete this payment record? This action is permanent.
    </div>

    <div class="apple-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Payment Information</h5>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Payment ID</label>
            <div class="fw-600"><code>#@Model.PaymentID</code></div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Linked Agreement</label>
            <div><code>Agr-@Model.AgreementID</code></div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Due Date</label>
            <div>@Model.DueDate.ToString("MMMM dd, yyyy")</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Amount Paid</label>
            <div class="fw-600">Rs. @Model.AmountPaid.ToString("N0")</div>
        </div>
        <div class="mb-0">
            <label class="form-label text-muted small uppercase">Payment Method</label>
            <div>@(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "—" : Model.PaymentMethod)</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="PaymentID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-apple btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
