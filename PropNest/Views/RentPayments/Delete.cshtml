@model PropNest.Models.RentPayment

@{
    ViewData["Title"] = "Delete Payment";
}

<h1>Delete Rent Payment</h1>
<h3>Are you sure you want to delete this?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-3">Lease ID</dt>
    <dd class="col-sm-9">@Model.LeaseID</dd>
    <dt class="col-sm-3">Amount Paid</dt>
    <dd class="col-sm-9">@Model.AmountPaid</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Due Date</dt>
    <dd class="col-sm-9">@Model.DueDate.ToShortDateString()</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="PaymentID" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
