@model IEnumerable<PropNest.Models.RentPayment>

@{
    ViewData["Title"] = "Rent Payments";
}

<h1>Rent Payments</h1>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" class="form-control" name="search" value="@ViewBag.Search" placeholder="Search payments by ID, agreement, status, or method" />
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Add Rent Payment</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Payment ID</th>
            <th>Agreement ID</th>
            <th>Payment Date</th>
            <th>Due Date</th>
            <th>Amount Paid</th>
            <th>Late Fee</th>
            <th>Payment Method</th>
            <th>Status</th>
            <th>Reminder</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(model => item.PaymentID)</td>
                <td>@Html.DisplayFor(model => item.AgreementID)</td>
                <td>@(item.PaymentDate.HasValue ? item.PaymentDate.Value.ToShortDateString() : "-")</td>
                <td>@Html.DisplayFor(model => item.DueDate)</td>
                <td>@Html.DisplayFor(model => item.AmountPaid)</td>
                <td>@item.LateFeeAmount.ToString("C")</td>
                <td>@Html.DisplayFor(model => item.PaymentMethod)</td>
                <td>@Html.DisplayFor(model => item.Status)</td>
                <td>
                    @(item.ReminderSent ? $"Sent {(item.ReminderSentAt?.ToShortDateString() ?? "")}" : "Pending")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.PaymentID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.PaymentID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.PaymentID">Delete</a> |
                    @if (item.ReminderSent == false)
                    {
                        <a asp-action="MarkReminderSent" asp-route-id="@item.PaymentID" class="btn btn-link">Send Reminder</a>
                    }
                    @if (item.ReceiptGenerated)
                    {
                        <a class="btn btn-link" href="https://localhost:7120/api/RentPayments/@item.PaymentID/receipt" target="_blank">Download Receipt</a>
                    }
                    else
                    {
                        <a asp-action="Details" asp-route-id="@item.PaymentID" class="btn btn-link">View / Generate Receipt</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
