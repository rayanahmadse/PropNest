@model PropNest.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Delete Request";
}

<div class="page-header mt-4">
    <div>
        <h1>Delete Maintenance Request</h1>
        <p>Confirm the removal of repair logs</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card max-width-600">
    <div class="alert alert-danger mb-4">
        <strong>⚠️ Warning:</strong> Are you sure you want to delete this maintenance request log? This action is permanent.
    </div>

    <div class="apple-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Request Information</h5>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Request Code</label>
            <div class="fw-600"><code>Req-@Model.RequestID</code></div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Property Unit</label>
            <div>Unit @(Model.PropertyUnit?.UnitNumber ?? "N/A")</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Category</label>
            <div>@Model.Category</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Assigned Staff</label>
            <div>@(Model.Staff?.FullName ?? "Unassigned")</div>
        </div>
        <div class="mb-0">
            <label class="form-label text-muted small uppercase">Logged Date</label>
            <div>@Model.DateLogged.ToString("MMMM dd, yyyy")</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="RequestID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-apple btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
