    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>MaintenanceRequest</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Unit Number
        </dt>
        <dd class = "col-sm-10">
            @(Model.PropertyUnit?.UnitNumber ?? "N/A")
        </dd>
        <dt class = "col-sm-2">
