@model PropNest.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>MaintenanceRequest</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="UnitID" class="control-label"></label>
                <select asp-for="UnitID" class ="form-control" asp-items="ViewBag.UnitID"></select>
                <span asp-validation-for="UnitID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StaffID" class="control-label"></label>
                <select asp-for="StaffID" class ="form-control" asp-items="ViewBag.StaffID"></select>
                <span asp-validation-for="StaffID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category" class="control-label"></label>
                <select asp-for="Category" class="form-control">
                    <option value="Plumbing">Plumbing</option>
                    <option value="Electrical">Electrical</option>
                    <option value="Structural">Structural</option>
                    <option value="General">General</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="alert alert-info">If a similar open request already exists for this unit and category, creation will be blocked.</div>
            </div>

            <div class="form-group">
                <label asp-for="DateLogged" class="control-label"></label>
                <input asp-for="DateLogged" class="form-control" />
                <span asp-validation-for="DateLogged" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="Open">Open</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Resolved">Resolved</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="true" id="createAndNotify" name="createAndNotify">
                    <label class="form-check-label" for="createAndNotify">Notify staff on creation</label>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
