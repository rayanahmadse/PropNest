@model PropNest.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>MaintenanceRequest</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Unit Number
        </dt>
        <dd class = "col-sm-10">
            @(Model.PropertyUnit?.UnitNumber ?? "N/A")
        </dd>
        <dt class = "col-sm-2">
            Staff
        </dt>
        <dd class = "col-sm-10">
            @(Model.Staff?.FullName ?? "N/A")
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Category)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateLogged)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateLogged)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.RequestID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
