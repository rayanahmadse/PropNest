@model PropNest.Models.LeaseContract

@{
    ViewData["Title"] = "Delete Lease";
}

<h1>Delete Lease Contract</h1>
<h3>Are you sure you want to delete this?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-3">Tenant</dt>
    <dd class="col-sm-9">@(Model.Tenant?.FullName ?? "-")</dd>
    <dt class="col-sm-3">Property Unit</dt>
    <dd class="col-sm-9">@(Model.PropertyUnit?.UnitNumber ?? "-")</dd>
    <dt class="col-sm-3">Monthly Rent</dt>
    <dd class="col-sm-9">@Model.MonthlyRent</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.LeaseStatus</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="LeaseID" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
