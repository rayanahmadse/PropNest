@model PropNest.Models.LeaseContract

@{
    ViewData["Title"] = "Lease Details";
}

<h1>Lease Contract Details</h1>
<hr />
<dl class="row">
    <dt class="col-sm-3">Tenant</dt>
    <dd class="col-sm-9">@(Model.Tenant?.FullName ?? "-")</dd>
    <dt class="col-sm-3">Property Unit</dt>
    <dd class="col-sm-9">@(Model.PropertyUnit?.UnitNumber ?? "-")</dd>
    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Monthly Rent</dt>
    <dd class="col-sm-9">@Model.MonthlyRent</dd>
    <dt class="col-sm-3">Security Deposit</dt>
    <dd class="col-sm-9">@(Model.SecurityDeposit.HasValue ? Model.SecurityDeposit.Value.ToString() : "-")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.LeaseStatus</dd>
    <dt class="col-sm-3">Version</dt>
    <dd class="col-sm-9">@Model.Version</dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.LeaseID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
