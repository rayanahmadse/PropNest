@model PropNest.Models.PropertyUnit

@{
    ViewData["Title"] = "Edit Property Unit";
}

<h1>Edit Property Unit</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="UnitID" />

            <div class="form-group mb-3">
                <label asp-for="UnitNumber" class="control-label"></label>
                <input asp-for="UnitNumber" class="form-control" />
                <span asp-validation-for="UnitNumber" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="PropertyType" class="control-label"></label>
                <input asp-for="PropertyType" class="form-control" />
                <span asp-validation-for="PropertyType" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FloorLevel" class="control-label"></label>
                <input asp-for="FloorLevel" class="form-control" />
                <span asp-validation-for="FloorLevel" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="AreaSqFt" class="control-label"></label>
                <input asp-for="AreaSqFt" class="form-control" />
                <span asp-validation-for="AreaSqFt" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Amenities" class="control-label"></label>
                <input asp-for="Amenities" class="form-control" />
                <span asp-validation-for="Amenities" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="Vacant">Vacant</option>
                    <option value="Occupied">Occupied</option>
                    <option value="Under Maintenance">Under Maintenance</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="AskingRent" class="control-label"></label>
                <input asp-for="AskingRent" class="form-control" />
                <span asp-validation-for="AskingRent" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="VacantSince" class="control-label"></label>
                <input asp-for="VacantSince" class="form-control" type="date" />
                <span asp-validation-for="VacantSince" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>
