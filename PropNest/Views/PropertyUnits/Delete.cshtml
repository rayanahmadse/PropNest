@model PropNest.Models.PropertyUnit

@{
    ViewData["Title"] = "Delete Property";
}

<div class="page-header mt-4">
    <div>
        <h1>Delete Property Unit</h1>
        <p>Confirm the removal of property unit from registry</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card max-width-600">
    <div class="alert alert-danger mb-4">
        <strong>⚠️ Warning:</strong> Are you sure you want to delete this property unit? This action is permanent and cannot be undone.
    </div>

    <div class="apple-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Property Information</h5>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Unit Number</label>
            <div class="fw-600">@Model.UnitNumber</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Property Type</label>
            <div>@Model.PropertyType</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Asking Rent</label>
            <div class="fw-600">Rs. @Model.AskingRent.ToString("N0")</div>
        </div>
        <div class="mb-0">
            <label class="form-label text-muted small uppercase">Rental Status</label>
            <div>@Model.Status</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="UnitID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-apple btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
