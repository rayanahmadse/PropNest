@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-header {
        margin-bottom: 48px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--color-border);
    }

    .dashboard-header h1 {
        margin-bottom: 8px;
    }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-bottom: 56px;
    }

    .quick-access-section h2 {
        margin-bottom: 28px;
        font-size: 1.5rem;
    }

    .quick-access-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
    }

    .quick-access-card {
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 28px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        text-decoration: none !important;
        color: inherit !important;
        display: flex;
        flex-direction: column;
    }

    .quick-access-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        border-color: var(--color-blue);
    }

    .quick-access-card h4 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--color-text);
    }

    .quick-access-card p {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.5;
    }
</style>

<!-- Header -->
<div class="dashboard-header">
    <h1>Dashboard</h1>
    <p style="color: var(--color-text-muted); margin: 0;">Overview of your property management system</p>
</div>

<!-- Key Metrics -->
<div class="metrics-grid">
    <!-- Rent Collected -->
    <a href="@Url.Action("Index", "RentPayments")" style="text-decoration: none; color: inherit;">
        <div class="metric-card">
            <div class="metric-label">Rent Collected</div>
            <div class="metric-value">@Model.TotalRentCollectedThisMonth.ToString("C0")</div>
            <div class="metric-subtitle">This month</div>
        </div>
    </a>

    <!-- Vacant Units -->
    <a href="@Url.Action("Index", "PropertyUnits")" style="text-decoration: none; color: inherit;">
        <div class="metric-card">
            <div class="metric-label">Vacant Units</div>
            <div class="metric-value">@Model.VacantUnitsCount</div>
            <div class="metric-subtitle">Available</div>
        </div>
    </a>

    <!-- Overdue Payments -->
    <a href="@Url.Action("Index", "RentPayments")" style="text-decoration: none; color: inherit;">
        <div class="metric-card">
            <div class="metric-label">Overdue Payments</div>
            <div class="metric-value" style="color: var(--color-red);">@Model.OverduePaymentsCount</div>
            <div class="metric-subtitle">Need attention</div>
        </div>
    </a>

    <!-- Expiring Agreements -->
    <a href="@Url.Action("Index", "RentalAgreements")" style="text-decoration: none; color: inherit;">
        <div class="metric-card">
            <div class="metric-label">Expiring Soon</div>
            <div class="metric-value">@Model.AgreementsExpiringIn30Days</div>
            <div class="metric-subtitle">In 30 days</div>
        </div>
    </a>
</div>

<!-- Quick Access Section -->
<div class="quick-access-section">
    <h2>Quick Access</h2>
    <div class="quick-access-grid">
        <a href="@Url.Action("Index", "Tenants")" class="quick-access-card">
            <h4>Tenants</h4>
            <p>View and manage all tenants</p>
        </a>

        <a href="@Url.Action("Index", "PropertyUnits")" class="quick-access-card">
            <h4>Properties</h4>
            <p>Manage your property portfolio</p>
        </a>

        <a href="@Url.Action("Index", "RentalAgreements")" class="quick-access-card">
            <h4>Agreements</h4>
            <p>Track rental agreements</p>
        </a>

        <a href="@Url.Action("Index", "RentPayments")" class="quick-access-card">
            <h4>Payments</h4>
            <p>Manage rent payments</p>
        </a>

        <a href="@Url.Action("Index", "Staff")" class="quick-access-card">
            <h4>Staff</h4>
            <p>Manage staff members</p>
        </a>

        <a href="@Url.Action("Index", "MaintenanceRequests")" class="quick-access-card">
            <h4>Maintenance</h4>
            <p>Track maintenance requests</p>
        </a>
    </div>
</div>
                    <div class="text-center">
                        <div class="metric-icon">⚠️</div>
                        <h6 class="metric-label mb-2">Overdue</h6>
                        <h3 class="metric-value" style="color: #FF3B30;">
                            @Model.OverduePaymentsCount
                        </h3>
                        <p class="metric-subtitle">Pending collection</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <a href="@Url.Action("Index", "RentalAgreements")" class="nav-card">
                <div class="metric-card apple-card h-100 p-4">
                    <div class="text-center">
                        <div class="metric-icon">📅</div>
                        <h6 class="metric-label mb-2">Expiring Soon</h6>
                        <h3 class="metric-value" style="color: #5AC8FA;">
                            @Model.AgreementsExpiringIn30Days
                        </h3>
                        <p class="metric-subtitle">In next 30 days</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<!-- Navigation Cards Section -->
<div class="nav-cards-section">
    <h2 class="nav-card-title">Quick Access</h2>
    <div class="row g-4">
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="Tenants" asp-action="Index" class="nav-card">
                <div class="apple-card h-100 p-5 text-center">
                    <span class="nav-icon">👥</span>
                    <h5 class="card-title fs-5 mb-2">Tenants</h5>
                    <p class="card-text text-muted mb-3">Manage tenant profiles and information</p>
                    <div class="d-flex align-items-center justify-content-center gap-1">
                        <span class="text-primary fw-600">View All</span>
                        <span>→</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
