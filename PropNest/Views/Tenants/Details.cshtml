@model PropNest.Models.TenantDetailsViewModel

@{
    ViewData["Title"] = "Tenant Details";
}

<div class="page-header mt-4">
    <div>
        <h1>Tenant Details</h1>
        <p>Profile info, active agreement, and history for @(Model.Tenant?.FullName ?? "Tenant")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Tenant?.TenantID" class="btn btn-apple">✏️ Edit Profile</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

@if (Model.Tenant != null)
{
    <div class="row g-4">
        <!-- Sidebar profile (4 cols) -->
        <div class="col-12 col-md-4">
            <!-- Profile Info -->
            <div class="apple-card p-4 mb-4">
                <h5 class="fw-bold mb-4 pb-2 border-bottom">Tenant Profile</h5>
                <div class="mb-3">
                    <label class="form-label text-muted small uppercase">Full Name</label>
                    <div class="fw-600">@Model.Tenant.FullName</div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small uppercase">CNIC / ID</label>
                    <div><code>@Model.Tenant.CNIC</code></div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small uppercase">Email Address</label>
                    <div><a href="mailto:@Model.Tenant.Email">@Model.Tenant.Email</a></div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small uppercase">Contact Number</label>
                    <div><a href="tel:@Model.Tenant.ContactNumber">@Model.Tenant.ContactNumber</a></div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small uppercase">Emergency Contact</label>
                    <div>@Model.Tenant.EmergencyContact</div>
                </div>
                <div class="mb-0">
                    <label class="form-label text-muted small uppercase">Status</label>
                    <div>
                        @{
                            var sc = Model.Tenant.Status == "Active" ? "status-active" : "status-inactive";
                        }
                        <span class="status-badge @sc">@Model.Tenant.Status</span>
                    </div>
                </div>
            </div>

            <!-- Active Agreement -->
            <div class="apple-card p-4">
                <h5 class="fw-bold mb-4 pb-2 border-bottom">Current Agreement</h5>
                @if (Model.ActiveAgreement != null)
                {
                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase">Agreement ID</label>
                        <div><code>Agr-@Model.ActiveAgreement.AgreementID</code></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase">Assigned Unit</label>
                        <div class="fw-600">Unit @(Model.ActiveUnit?.UnitNumber ?? "—")</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase">Rent / Deposit</label>
                        <div>
                            Rs. @Model.ActiveAgreement.MonthlyRent.ToString("N0") /mo<br />
                            <span class="text-muted small">Deposit: Rs. @Model.ActiveAgreement.SecurityDeposit.ToString("N0")</span>
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label text-muted small uppercase">Agreement Period</label>
                        <div>@Model.ActiveAgreement.StartDate.ToString("MMM dd, yyyy") to @Model.ActiveAgreement.EndDate.ToString("MMM dd, yyyy")</div>
                    </div>
                }
                else
                {
                    <div class="text-center py-3 text-muted small">No active rental agreement registered.</div>
                }
            </div>
        </div>

        <!-- History tabs/tables (8 cols) -->
        <div class="col-12 col-md-8">
            <!-- Rental History -->
            <div class="apple-card p-4 mb-4">
                <h5 class="fw-bold mb-3">All Rental Agreements</h5>
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th>Agreement ID</th>
                                <th>Unit</th>
                                <th>Rent</th>
                                <th>Period</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Agreements.Any())
                            {
                                @foreach (var agreement in Model.Agreements)
                                {
                                    <tr class="align-middle">
                                        <td><code>Agr-@agreement.AgreementID</code></td>
                                        <td>Unit @agreement.UnitID</td>
                                        <td>Rs. @agreement.MonthlyRent.ToString("N0")</td>
                                        <td>@agreement.StartDate.ToString("MM/dd/yy") - @agreement.EndDate.ToString("MM/dd/yy")</td>
                                        <td>
                                            @{
                                                var asc = agreement.AgreementStatus == "Active" ? "status-active" : "status-inactive";
                                            }
                                            <span class="status-badge @asc" style="font-size:0.7rem; padding:0.15rem 0.45rem;">@agreement.AgreementStatus</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-3 text-muted small">No agreements listed.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payment History -->
            <div class="apple-card p-4 mb-4">
                <h5 class="fw-bold mb-3">Payment History</h5>
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th>Payment ID</th>
                                <th>Due Date</th>
                                <th>Payment Date</th>
                                <th>Late Fee</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RentPayments.Any())
                            {
                                @foreach (var payment in Model.RentPayments)
                                {
                                    <tr class="align-middle">
                                        <td><code>#@payment.PaymentID</code></td>
                                        <td>@payment.DueDate.ToString("MMM dd, yyyy")</td>
                                        <td>@(payment.PaymentDate.HasValue ? payment.PaymentDate.Value.ToString("MMM dd, yyyy") : "—")</td>
                                        <td>Rs. @payment.LateFeeAmount.ToString("N0")</td>
                                        <td>
                                            @{
                                                var psc = payment.Status == "Paid" ? "status-paid" : "status-pending";
                                            }
                                            <span class="status-badge @psc" style="font-size:0.7rem; padding:0.15rem 0.45rem;">@payment.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-3 text-muted small">No payment history found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Maintenance Requests -->
            <div class="apple-card p-4">
                <h5 class="fw-bold mb-3">Maintenance Request History</h5>
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th>Request ID</th>
                                <th>Category</th>
                                <th>Date Logged</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.MaintenanceRequests.Any())
                            {
                                @foreach (var request in Model.MaintenanceRequests)
                                {
                                    <tr class="align-middle">
                                        <td><code>Req-@request.RequestID</code></td>
                                        <td>@request.Category</td>
                                        <td>@request.DateLogged.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @{
                                                var msc = request.Status == "Resolved" ? "status-completed" : "status-pending";
                                            }
                                            <span class="status-badge @msc" style="font-size:0.7rem; padding:0.15rem 0.45rem;">@request.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-3 text-muted small">No maintenance requests logged.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
