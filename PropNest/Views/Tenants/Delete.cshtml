@model PropNest.Models.Tenant

@{
    ViewData["Title"] = "Delete Tenant";
}

<div class="page-header mt-4">
    <div>
        <h1>Delete Tenant</h1>
        <p>Confirm the removal of tenant profile and records</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card max-width-600">
    <div class="alert alert-danger mb-4">
        <strong>⚠️ Warning:</strong> Are you sure you want to delete this tenant profile? This action is permanent and cannot be undone.
    </div>

    <div class="apple-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Tenant Information</h5>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Full Name</label>
            <div class="fw-600">@Model.FullName</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">CNIC / ID</label>
            <div><code>@Model.CNIC</code></div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Email Address</label>
            <div>@Model.Email</div>
        </div>
        <div class="mb-0">
            <label class="form-label text-muted small uppercase">Contact Number</label>
            <div>@Model.ContactNumber</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="TenantID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-apple btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
