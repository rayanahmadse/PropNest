@model PropNest.Models.RentalAgreement

@{
    ViewData["Title"] = "Create Rental Agreement";
}

<h1>Create Rental Agreement</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="TenantID" class="control-label">Tenant</label>
                <select asp-for="TenantID" class="form-control" asp-items="ViewBag.TenantID">
                    <option value="">-- Select Tenant --</option>
                </select>
                <span asp-validation-for="TenantID" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="UnitID" class="control-label">Property Unit</label>
                <select asp-for="UnitID" class="form-control" asp-items="ViewBag.UnitID">
                    <option value="">-- Select Unit (Vacant Only) --</option>
                </select>
                <span asp-validation-for="UnitID" class="text-danger"></span>
                <small class="text-muted">Only vacant units are available for new rental agreements.</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MonthlyRent" class="control-label"></label>
                <input asp-for="MonthlyRent" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="MonthlyRent" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SecurityDeposit" class="control-label"></label>
                <input asp-for="SecurityDeposit" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="SecurityDeposit" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AgreementStatus" class="control-label">Status</label>
                <select asp-for="AgreementStatus" class="form-control">
                    <option value="Active">Active</option>
                    <option value="Expired">Expired</option>
                    <option value="Terminated">Terminated</option>
                </select>
                <span asp-validation-for="AgreementStatus" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Version" class="control-label"></label>
                <input asp-for="Version" type="number" class="form-control" />
                <span asp-validation-for="Version" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
