@model PropNest.Models.RentalAgreement

@{
    ViewData["Title"] = "Delete Agreement";
}

<div class="page-header mt-4">
    <div>
        <h1>Delete Rental Agreement</h1>
        <p>Confirm the removal of rental agreement</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card max-width-600">
    <div class="alert alert-danger mb-4">
        <strong>⚠️ Warning:</strong> Are you sure you want to delete this agreement? Deleting this contract will automatically mark the property unit as <strong>Vacant</strong>.
    </div>

    <div class="apple-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Agreement Information</h5>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Agreement Code</label>
            <div class="fw-600"><code>Agr-@Model.AgreementID</code></div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Tenant Name</label>
            <div>@(Model.Tenant?.FullName ?? "N/A")</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Property Unit</label>
            <div>Unit @(Model.PropertyUnit?.UnitNumber ?? "N/A")</div>
        </div>
        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Monthly Rent Rate</label>
            <div class="fw-600">Rs. @Model.MonthlyRent.ToString("N0")</div>
        </div>
        <div class="mb-0">
            <label class="form-label text-muted small uppercase">Agreement End Date</label>
            <div>@Model.EndDate.ToString("MMMM dd, yyyy")</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="AgreementID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-apple btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
