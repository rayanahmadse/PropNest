@model PropNest.Models.RentalAgreement

@{
    ViewData["Title"] = "Delete Rental Agreement";
}

<h1>Delete Rental Agreement</h1>

<h3>Are you sure you want to delete this rental agreement?</h3>
<div class="alert alert-info" role="alert">
    <strong>⚠️ Note:</strong> Deleting this agreement will automatically mark the unit as <strong>Vacant</strong>, making it available for new rental agreements.
</div>
<hr />
<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-3">Agreement ID</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AgreementID)</dd>

            <dt class="col-sm-3">Tenant</dt>
            <dd class="col-sm-9">
                @if (Model.Tenant != null)
                {
                    @Html.DisplayFor(model => model.Tenant.FullName)
                }
            </dd>

            <dt class="col-sm-3">Property Unit</dt>
            <dd class="col-sm-9">
                @if (Model.PropertyUnit != null)
                {
                    @Html.DisplayFor(model => model.PropertyUnit.UnitNumber)
                }
            </dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.StartDate)</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDate)</dd>

            <dt class="col-sm-3">Monthly Rent</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.MonthlyRent)</dd>

            <dt class="col-sm-3">Security Deposit</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.SecurityDeposit)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AgreementStatus)</dd>

            <dt class="col-sm-3">Version</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Version)</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="AgreementID" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
