@model PropNest.Models.RentalAgreement
@{
    ViewData["Title"] = "Agreement Details";
}

<div class="page-header mt-4">
    <div>
        <h1>Rental Agreement Details</h1>
        <p>Agreement parameters, monthly rent terms, and contract version for Agr-@Model.AgreementID</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.AgreementID" class="btn btn-apple">✏️ Edit Agreement</a>
        <a asp-action="Delete" asp-route-id="@Model.AgreementID" class="btn btn-outline-danger">🗑 Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <!-- Agreement parameters Card (8 columns) -->
    <div class="col-12 col-md-8">
        <div class="apple-card p-4">
            <h5 class="fw-bold mb-4 pb-2 border-bottom">Agreement Terms</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Tenant Link</label>
                    <div>
                        @if (Model.Tenant != null)
                        {
                            <a class="fw-600 text-decoration-none" asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.Tenant.TenantID">
                                👤 @Model.Tenant.FullName
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No tenant assigned.</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Property Unit Link</label>
                    <div>
                        @if (Model.PropertyUnit != null)
                        {
                            <a class="fw-600 text-decoration-none" asp-controller="PropertyUnits" asp-action="Details" asp-route-id="@Model.PropertyUnit.UnitID">
                                🏢 Unit @Model.PropertyUnit.UnitNumber
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No unit assigned.</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Start Date</label>
                    <div>@Model.StartDate.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">End Date</label>
                    <div>@Model.EndDate.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Monthly Rent Rate</label>
                    <div class="fw-600">Rs. @Model.MonthlyRent.ToString("N0")</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small uppercase">Security Deposit Amount</label>
                    <div>Rs. @Model.SecurityDeposit.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Info/Meta Card (4 columns) -->
    <div class="col-12 col-md-4">
        <div class="apple-card p-4">
            <h5 class="fw-bold mb-4 pb-2 border-bottom">System Status</h5>
            <div class="mb-4">
                <label class="form-label text-muted small uppercase">Agreement Status</label>
                <div>
                    @{
                        var sc = Model.AgreementStatus switch {
                            "Active"     => "status-active",
                            "Terminated" => "status-overdue",
                            "Expired"    => "status-inactive",
                            _            => "status-pending"
                        };
                    }
                    <span class="status-badge @sc">@Model.AgreementStatus</span>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label text-muted small uppercase">Version Control</label>
                <div>v@(Model.Version)</div>
            </div>
            <div class="mb-0">
                <label class="form-label text-muted small uppercase">Agreement Code</label>
                <div><code>Agr-@Model.AgreementID</code></div>
            </div>
        </div>
    </div>
</div>
