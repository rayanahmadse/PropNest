@model IEnumerable<PropNest.Models.RentalAgreement>
@{
    ViewData["Title"] = "Rental Agreements";
}

<div class="page-header mt-4">
    <div>
        <h1>Rental Agreements</h1>
        <p>Manage rental agreements, monthly rents, and security deposits</p>
    </div>
    <a asp-action="Create" class="btn btn-apple">+ Add Rental Agreement</a>
</div>

@if (ViewBag.Filter == "ExpiringSoon")
{
    <div class="alert alert-info d-flex align-items-center justify-content-between mb-4 border-0 shadow-sm" style="background-color: #fffbeb; color: #d97706; border-radius: var(--radius-md);">
        <div class="d-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 1.25rem; height: 1.25rem;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
            <span>Showing only active <strong>Agreements Expiring Within 30 Days</strong>.</span>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-apple" style="padding: 0.25rem 0.75rem; font-size: 0.8rem; background-color: #d97706; border-color: #d97706;">Show All Agreements</a>
    </div>
}

@if (Model.Any())
{
    <div class="apple-card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Tenant</th>
                        <th>Unit</th>
                        <th>End Date</th>
                        <th>Monthly Rent</th>
                        <th>Status</th>
                        <th class="text-center pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="align-middle">
                            <td class="ps-4"><span class="fw-600">@(item.Tenant?.FullName ?? "N/A")</span></td>
                            <td><code>Unit @(item.PropertyUnit?.UnitNumber ?? "N/A")</code></td>
                            <td>@item.EndDate.ToString("MMM dd, yyyy")</td>
                            <td><span class="fw-600">Rs. @item.MonthlyRent.ToString("N0")</span></td>
                            <td>
                                @{
                                    var sc = item.AgreementStatus switch {
                                        "Active"     => "status-active",
                                        "Terminated" => "status-overdue",
                                        "Expired"    => "status-inactive",
                                        _            => "status-pending"
                                    };
                                }
                                <span class="status-badge @sc">@item.AgreementStatus</span>
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group-custom justify-content-center">
                                    <a asp-action="Details" asp-route-id="@item.AgreementID" class="btn btn-sm">View Details</a>
                                    <a asp-action="Edit"    asp-route-id="@item.AgreementID" class="btn btn-sm">Edit</a>
                                    <a asp-action="Delete"  asp-route-id="@item.AgreementID" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" style="width:3rem;height:3rem;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
        </div>
        <h4>No Agreements Found</h4>
        <p>Create a rental agreement to link a tenant to a property unit.</p>
        <a asp-action="Create" class="btn btn-apple">+ Create First Agreement</a>
    </div>
}
